TMDB_API_READ_ACCESS_TOKEN=your_tmdb_read_access_token
# Optional alternative if you prefer v3 query-param auth:
# TMDB_API_KEY=your_tmdb_api_key

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=CineMatch <onboarding@resend.dev>
RESEND_TEST_MODE=true
RESEND_TEST_TO=delivered@resend.dev

# Optional but recommended for email links:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: error monitoring (enables Sentry in next.config + instrumentation when set)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Admin API (/api/admin/*): server-only allowlist + Supabase app_metadata.role === "admin"
# ADMIN_EMAILS=comma@separated,emails
# ADMIN_USER_IDS=comma,separated,uuids
# ADMIN_DASHBOARD_EMAIL=single@email
# ADMIN_EMAIL=single@email

# In-memory offline demo (only when Supabase URL/key are unset): shared password for seeded users in mock-data.ts
# NEXT_PUBLIC_OFFLINE_DEMO_PASSWORD=choose-a-local-secret
